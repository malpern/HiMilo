{
  "manifest_version": 3,
  "name": "VoxClaw",
  "description": "Pauses YouTube when VoxClaw speaks, resumes when it finishes.",
  "version": "1.0.0",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "tabs",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "http://localhost:4140/*",
    "https://*.youtube.com/*",
    "https://youtube.com/*",
    "https://youtu.be/*",
    "https://*.youtube-nocookie.com/*"
  ],
  "action": {
    "default_title": "VoxClaw",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    },
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "service_worker.js"
  }
}
